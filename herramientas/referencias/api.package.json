{
  "name": "@sistema-arabe/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only --exit-child src/main.ts",
    "typecheck": "tsc --noEmit",
