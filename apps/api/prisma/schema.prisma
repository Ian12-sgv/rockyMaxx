  cuentaBancoRef CtaBancos   @relation(fields: [CuentaBanco], references: [Codigo], onDelete: Cascade, onUpdate: Cascade)
  usuarioRef     Usuarios    @relation(fields: [Usuario], references: [CodUsuario], onDelete: NoAction, onUpdate: Cascade)

  @@id([NumeroDeposito, CuentaBanco, Serie])
  @@map("DEPOSITOS")
